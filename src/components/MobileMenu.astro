---
export interface Props {
  activePage?: string;
}

const { activePage: _activePage = '' } = Astro.props;
void _activePage; // reserved for future active-state highlighting
---

<div class="mobile-menu" id="mobile-menu" aria-label="行動裝置選單" role="dialog" aria-modal="true">
  <div class="mobile-menu-header">
    <div class="mobile-menu-brand">
      <svg width="32" height="32" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="18" cy="18" r="17" stroke="currentColor" stroke-width="1.5" />
        <line x1="11" y1="9" x2="25" y2="9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        <line x1="11" y1="13" x2="25" y2="13" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        <line x1="11" y1="17" x2="25" y2="17" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        <line x1="11" y1="21" x2="16" y2="21" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        <line x1="20" y1="21" x2="25" y2="21" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        <line x1="11" y1="25" x2="16" y2="25" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        <line x1="20" y1="25" x2="25" y2="25" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        <line x1="11" y1="29" x2="16" y2="29" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        <line x1="20" y1="29" x2="25" y2="29" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
      </svg>
      <span>易經研究所</span>
    </div>
    <button class="mobile-close" id="mobile-close" aria-label="關閉選單">
      <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M5 5L15 15M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div class="mobile-menu-body">
    <a href="/" class="mobile-link">首頁</a>
    <a href="/about" class="mobile-link">關於</a>

    <!-- 文章 expandable -->
    <div class="mobile-services-group">
      <button class="mobile-services-toggle" data-target="mobile-articles-list" aria-expanded="false">
        文章
        <svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M5 7L9 11L13 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <div class="mobile-services-list" id="mobile-articles-list">
        <a href="/articles">所有文章</a>
        <a href="/articles?category=經典導讀">經典導讀</a>
        <a href="/articles?category=卦象解析">卦象解析</a>
        <a href="/articles?category=爻辭探討">爻辭探討</a>
        <a href="/articles?category=哲學思想">哲學思想</a>
        <a href="/articles?category=實用占卜">實用占卜</a>
      </div>
    </div>

    <!-- 工具 expandable -->
    <div class="mobile-services-group">
      <button class="mobile-services-toggle" data-target="mobile-tools-list" aria-expanded="false">
        工具
        <svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M5 7L9 11L13 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <div class="mobile-services-list" id="mobile-tools-list">
        <a href="/tools">所有工具</a>
        <a href="/tools/divination">線上占卦</a>
        <a href="/tools/hexagram-lookup">卦象查詢</a>
        <a href="/tools/ai-interpretation">AI 智能解卦</a>
      </div>
    </div>
  </div>

  <div class="mobile-menu-footer">
    <a href="/tools/divination" class="mobile-cta">
      <svg width="18" height="18" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5" />
        <path d="M5 8H11M8 5V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      免費占卦
    </a>
    <a href="/tools/ai-interpretation" class="mobile-cta mobile-cta--secondary">
      AI 智能解卦
    </a>
  </div>
</div>
