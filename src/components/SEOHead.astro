---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  locale?: string;
  publishedTime?: string;
  modifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
  robots?: string;
  schema?: string;
}

const {
  title,
  description = '易經研究所提供免費線上占卦、AI 智能解卦、六十四卦完整解析，帶你探索三千年東方智慧。',
  canonical,
  keywords = '易經,周易,占卦,六十四卦,八卦,卜卦,I Ching,算命,解卦,爻辭,卦象',
  ogImage = 'https://zenkami.com/images/og-default.webp',
  ogType = 'website',
  locale = 'zh_TW',
  publishedTime,
  modifiedTime,
  articleSection,
  articleTags = [],
  robots = 'index, follow',
  schema,
} = Astro.props;

const site = 'https://zenkami.com';
const canonicalURL = canonical || new URL(Astro.url.pathname, site).href;
const fullOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, site).href;

/* JSON-LD: WebSite + SiteNavigationElement */
const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${site}/#website`,
      url: site,
      name: '易經研究所',
      description,
      inLanguage: 'zh-TW',
      publisher: {
        '@type': 'Organization',
        name: '易經研究所',
        url: site,
        logo: {
          '@type': 'ImageObject',
          url: `${site}/logo.svg`,
        },
      },
    },
    {
      '@type': 'SiteNavigationElement',
      '@id': `${site}/#navigation`,
      name: ['首頁', '關於', '文章', '線上占卦', '卦象查詢', 'AI 智能解卦'],
      url: [
        site,
        `${site}/about`,
        `${site}/articles`,
        `${site}/tools/divination`,
        `${site}/tools/hexagram-lookup`,
        `${site}/tools/ai-interpretation`,
      ],
    },
  ],
});

/* JSON-LD: Article enhancement (if article page) */
const articleSchema = publishedTime
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      image: fullOgImage,
      datePublished: publishedTime,
      ...(modifiedTime && { dateModified: modifiedTime }),
      ...(articleSection && { articleSection }),
      inLanguage: 'zh-TW',
      isAccessibleForFree: true,
      speakable: {
        '@type': 'SpeakableSpecification',
        cssSelector: ['.article-lead', '.article-body h2'],
      },
      publisher: {
        '@type': 'Organization',
        name: '易經研究所',
        url: site,
      },
    })
  : null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content={robots} />
<meta name="generator" content={Astro.generator} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="易經研究所" />
<meta property="og:locale" content={locale} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{articleSection && <meta property="article:section" content={articleSection} />}
{articleTags.map((tag) => <meta property="article:tag" content={tag} />)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title="易經研究所 RSS" href={`${site}/rss.xml`} />

<!-- Structured Data -->
<script type="application/ld+json" set:html={websiteSchema} />
{articleSchema && <script type="application/ld+json" set:html={articleSchema} />}
{schema && <script type="application/ld+json" set:html={schema} />}
