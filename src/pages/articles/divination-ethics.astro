const schema = JSON.stringify({ "@context": "https://schema.org", "@type": "BlogPosting", "headline": title, "description": description, "datePublished": "2026-03-10", "dateModified": "2026-03-10", "author": { "@type": "Organization", "name": "易經研究所" }, "publisher": { "@type": "Organization", "name": "易經研究所" } });
---

<Base title={`${title} | 易經研究所`} description={description} canonical={`${site}/articles/divination-ethics`} keywords="占卜禁忌,問卦態度,占卦心法,占卜心理準備,易經占卦規矩" schema={schema} ogType="article" ogImage="https://zenkami.com/articles/hero/article-ethics.webp" articleSection="實用占卜" activePage="articles">

