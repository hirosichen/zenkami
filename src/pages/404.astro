---
import Base from '../layouts/Base.astro';
---

<Base title="找不到頁面 | 易經研究所" description="此頁面不存在。" robots="noindex,nofollow">

<section class="page-hero" style="min-height:60vh;display:flex;align-items:center">
  <div class="container" style="text-align:center">
    <div style="font-size:6rem;margin-bottom:1rem;opacity:.6;font-family:var(--ff-serif)">☰</div>
    <h1 style="font-size:clamp(3rem,8vw,6rem);opacity:.15;font-family:var(--ff-serif);margin-bottom:-1rem">404</h1>
    <h2 style="font-size:1.5rem;margin-bottom:1rem">此路不通，非吉非凶</h2>
    <p style="color:var(--c-text-muted,var(--mid-gray));max-width:480px;margin:0 auto 2rem">
      你要找的頁面已經消失在天地之間。正如易經所言：「窮則變，變則通」——讓我們換條路走。
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
      <a href="/" class="cta-btn cta-btn--primary" style="display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.75rem;border-radius:8px;font-weight:600;text-decoration:none">回到首頁</a>
      <a href="/tools/divination" class="cta-btn cta-btn--secondary" style="display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.75rem;border-radius:8px;font-weight:600;text-decoration:none">占一卦看看</a>
    </div>
  </div>
</section>

</Base>
