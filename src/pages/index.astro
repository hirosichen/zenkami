<style>
  .hero{position:relative;min-height:90vh;display:flex;align-items:center;justify-content:center;overflow:hidden;padding:6rem 0 4rem;background:linear-gradient(135deg, var(--near-black) 0%, var(--dark-indigo) 40%, #1a2e3e 70%, #1f2b40 100%)}
  .hero::before{content:'';position:absolute;inset:0;z-index:0;background:radial-gradient(ellipse at 30% 40%, rgba(45,138,86,0.15) 0%, transparent 55%),radial-gradient(ellipse at 70% 60%, rgba(184,134,11,0.1) 0%, transparent 50%);pointer-events:none}
  .hero-canvas{position:absolute;inset:0;z-index:0;pointer-events:none}
  .hero-inner{position:relative;z-index:1;text-align:center;max-width:720px}
  .hero-title{font-size:clamp(2.75rem,7vw,4.5rem);margin-bottom:1.25rem;line-height:1.1;font-weight:800;letter-spacing:0.02em}
  .hero-desc{color:var(--c-text-muted);font-size:1.1rem;max-width:560px;margin:0 auto 2rem}
  .hero-form{display:flex;gap:.75rem;max-width:520px;margin:0 auto 1.5rem}
  .hero-form .form-input{flex:1}
  .hero-form .btn-primary{transition:background 0.2s ease,box-shadow 0.2s ease,transform 0.2s ease}
  .hero-form .btn-primary:hover{background:var(--jade-light);box-shadow:0 4px 20px rgba(45,138,86,0.35);transform:translateY(-2px)}
  .hero-form .btn-primary:active{transform:translateY(0);box-shadow:0 2px 8px rgba(45,138,86,0.25)}
  .hero-proof{color:var(--c-text-muted);font-size:.85rem}
  .hero-proof strong{color:var(--c-primary)}
  @media(max-width:640px){.hero-form{flex-direction:column}}
</style>

<script>
  // Hero form redirect
  document.getElementById('heroForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const q = (document.getElementById('heroQuestion') as HTMLInputElement)?.value;
    const url = q ? `/tools/divination?q=${encodeURIComponent(q)}&auto=1` : '/tools/divination?auto=1';
    window.location.href = url;
  });

  // Bagua particle canvas
  (function() {
    const canvas = document.getElementById('baguaCanvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    let w = 0, h = 0;
    const symbols = ['☰','☱','☲','☳','☴','☵','☶','☷','☯','⚊','⚋'];
    interface Particle { x:number; y:number; vx:number; vy:number; s:string; size:number; alpha:number; }
    let particles: Particle[] = [];

    function resize() {
      w = canvas.width = canvas.offsetWidth;
      h = canvas.height = canvas.offsetHeight;
    }

    function init() {
      resize();
      particles = [];
      const count = Math.min(60, Math.floor(w * h / 15000));
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.3,
          vy: (Math.random() - 0.5) * 0.3,
          s: symbols[Math.floor(Math.random() * symbols.length)],
          size: 12 + Math.random() * 16,
          alpha: 0.05 + Math.random() * 0.12,
        });
      }
    }

    function draw() {
      ctx!.clearRect(0, 0, w, h);
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < -20) p.x = w + 20;
        if (p.x > w + 20) p.x = -20;
        if (p.y < -20) p.y = h + 20;
        if (p.y > h + 20) p.y = -20;
        ctx!.globalAlpha = p.alpha;
        ctx!.font = `${p.size}px serif`;
        ctx!.fillStyle = '#c9a84c';
        ctx!.fillText(p.s, p.x, p.y);
      }
      ctx!.globalAlpha = 1;
      requestAnimationFrame(draw);
    }

    init();
    draw();
    window.addEventListener('resize', resize);
  })();

  // Stat counter animation
  (function() {
    const row = document.getElementById('statsRow');
    if (!row) return;
    const nums = row.querySelectorAll('.stat-number');
    let animated = false;

    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && !animated) {
        animated = true;
        nums.forEach(el => {
          const target = parseFloat(el.getAttribute('data-target') || '0');
          const isDecimal = el.getAttribute('data-decimal') === 'true';
          const duration = 1500;
          const start = performance.now();
          function tick(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = eased * target;
            el.textContent = isDecimal ? current.toFixed(1) : Math.floor(current).toLocaleString() + (target >= 2000 ? '+' : '');
            if (progress < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        });
      }
    }, { threshold: 0.3 });
    observer.observe(row);
  })();
</script>
