---
import Base from '../layouts/Base.astro';

const site = 'https://zenkami.com';
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "易經研究所",
      "url": site,
      "description": "免費線上易經占卦平台，AI 智能解卦，六十四卦完整解析",
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${site}/tools/hexagram-lookup?q={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "name": "易經研究所",
      "url": site,
      "description": "致力於將三千年易經智慧帶入現代生活"
    }
  ]
});
