---
import Base from '../../layouts/Base.astro';
const site = 'https://zenkami.com';
---

<Base title="線上占卦 | 易經研究所" description="免費線上三幣法占卦工具。模擬傳統擲幣過程，即時獲得六十四卦卦象、變爻與 AI 智能解卦。" canonical={`${site}/tools/divination`} keywords="線上占卦,三幣法,免費占卦,易經占卦,擲銅錢,卜卦,AI解卦" activePage="tools">

<section class="page-hero" style="position:relative;overflow:hidden">
  <div class="hero-bg-image" style="opacity:.15">
    <img src="/images/hero/scholar-divination.webp" alt="" loading="eager" fetchpriority="high" width="1200" height="630" />
  </div>
  <div class="container" style="position:relative;z-index:1">
    <p class="section-overline">免費占卦工具</p>
    <h1>線上三幣法占卦</h1>
    <p>模擬傳統三枚銅錢占卦法，六次擲幣即得卦象。帶著你的問題，讓易經為你指引方向。</p>
  </div>
</section>

<section class="section" style="padding-top:1rem">
  <div class="container" style="max-width:720px">

    <!-- Step 1: Question -->
    <div id="step-question" class="divination-step">
      <div class="card" style="text-align:center;padding:2.5rem">
        <h2 style="font-size:1.3rem;margin-bottom:1rem">在心中默想你的問題</h2>
        <p style="color:var(--mid-gray,var(--c-text-muted));margin-bottom:1.5rem;font-size:.9rem">可以在下方輸入問題（選填），或直接開始占卦。建議問題明確、具體。</p>
        <div style="margin-bottom:1.5rem">
          <textarea id="questionInput" class="form-input" placeholder="例如：我應該接受這份新工作嗎？" rows="3" style="resize:vertical"></textarea>
        </div>
        <button id="startBtn" class="cta-btn cta-btn--primary" style="display:inline-flex;align-items:center;gap:.5rem;padding:.85rem 2rem;border-radius:8px;font-weight:600;font-size:1rem;cursor:pointer">開始占卦</button>
      </div>
    </div>

    <!-- Step 2: Coin throws animation -->
    <div id="step-throwing" class="divination-step" style="display:none">
      <div class="card" style="text-align:center;padding:2.5rem">
        <h2 style="font-size:1.3rem;margin-bottom:1.5rem">擲幣中...</h2>
        <div id="throwsContainer" style="display:flex;flex-direction:column;gap:1rem;align-items:center"></div>
      </div>
    </div>

    <!-- Step 3: Result -->
    <div id="step-result" class="divination-step" style="display:none">
      <div class="card" style="padding:2rem">
        <div style="text-align:center;margin-bottom:2rem">
          <p class="section-overline" style="font-size:.75rem">占卦結果</p>
          <div id="hexagramViz" style="display:flex;flex-direction:column;align-items:center;gap:6px;margin:1.5rem 0"></div>
          <h2 id="hexagramName" style="font-size:1.75rem;margin-bottom:.25rem"></h2>
          <p id="hexagramPinyin" style="color:var(--mid-gray,var(--c-text-muted));font-size:.9rem"></p>
        </div>

        <!-- Nature & Keywords -->
        <div id="hexagramMeta" style="margin-bottom:2rem;padding:1rem 1.25rem;background:var(--off-white,#f5f4f0);border-radius:10px;text-align:center">
          <p id="hexagramNature" style="font-size:.9rem;color:var(--mid-gray,#6b7280);margin-bottom:.5rem"></p>
          <div id="hexagramKeywords" style="display:flex;gap:.5rem;justify-content:center;flex-wrap:wrap"></div>
        </div>

        <!-- Judgment -->
        <div style="margin-bottom:2rem">
          <h3 style="font-size:1.1rem;margin-bottom:.5rem;color:var(--jade,var(--c-primary))">卦辭</h3>
          <blockquote id="hexagramJudgment" style="border-left:3px solid var(--jade,var(--c-primary));padding:.75rem 1rem;background:var(--jade-subtle,rgba(45,138,86,.08));border-radius:0 8px 8px 0;font-family:var(--ff-serif);margin:0"></blockquote>
        </div>

        <!-- Image -->
        <div style="margin-bottom:2rem">
          <h3 style="font-size:1.1rem;margin-bottom:.5rem;color:var(--jade,var(--c-primary))">象傳</h3>
          <blockquote id="hexagramImage" style="border-left:3px solid var(--bronze,#b8860b);padding:.75rem 1rem;background:var(--bronze-subtle,rgba(184,134,11,.1));border-radius:0 8px 8px 0;font-family:var(--ff-serif);margin:0"></blockquote>
        </div>

        <!-- All 6 lines -->
        <div style="margin-bottom:2rem">
          <h3 style="font-size:1.1rem;margin-bottom:1rem;color:var(--jade,var(--c-primary))">六爻解析</h3>
          <div id="allLinesContent"></div>
        </div>

        <!-- Changing lines highlight -->
        <div id="changingLinesSection" style="display:none;margin-bottom:2rem">
          <h3 style="font-size:1.1rem;margin-bottom:1rem;color:var(--bronze,#b8860b)">動爻提示</h3>
          <div id="changingLinesContent"></div>
        </div>

        <!-- Transformed hexagram -->
        <div id="transformedSection" style="display:none;margin-bottom:2rem;padding:1.5rem;background:var(--jade-subtle,rgba(45,138,86,.08));border-radius:12px;border:1px solid rgba(45,138,86,.2)">
          <h3 style="font-size:1.1rem;margin-bottom:1rem;text-align:center">之卦（變卦）</h3>
          <div id="transformedViz" style="display:flex;flex-direction:column;align-items:center;gap:6px;margin-bottom:1rem"></div>
          <h4 id="transformedName" style="text-align:center;font-size:1.25rem;margin-bottom:.25rem"></h4>
          <p id="transformedPinyin" style="text-align:center;color:var(--mid-gray,var(--c-text-muted));font-size:.85rem;margin-bottom:1rem"></p>
          <blockquote id="transformedJudgment" style="border-left:3px solid var(--jade,var(--c-primary));padding:.75rem 1rem;background:rgba(255,255,255,.5);border-radius:0 8px 8px 0;font-family:var(--ff-serif);margin:0"></blockquote>
        </div>

        <!-- AI Interpretation with Email Gate -->
        <div id="aiSection" style="margin-bottom:2rem">
          <!-- Email gate -->
          <div id="aiGate" class="ai-gate">
            <div class="ai-gate-icon">
              <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 2a4 4 0 0 1 4 4v1h1a3 3 0 0 1 3 3v1a3 3 0 0 1-3 3h-1v4a4 4 0 0 1-8 0v-4H7a3 3 0 0 1-3-3v-1a3 3 0 0 1 3-3h1V6a4 4 0 0 1 4-4z"/></svg>
            </div>
            <h3 class="ai-gate-title">解鎖 AI 智能解卦</h3>
            <p class="ai-gate-desc">輸入你的 Email，即可獲得 AI 為你量身打造的深度解讀。<br/><span style="font-size:.8rem;opacity:.7">同時訂閱每週易經洞見，隨時可退訂。</span></p>
            <form id="aiEmailForm" class="ai-gate-form">
              <input type="email" id="aiEmailInput" placeholder="your@email.com" required class="form-input" style="text-align:center;max-width:320px;margin:0 auto" />
              <button type="submit" id="aiUnlockBtn" class="cta-btn cta-btn--primary" style="display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 2rem;border-radius:8px;font-weight:600;cursor:pointer;margin-top:.75rem">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 2a4 4 0 0 1 4 4v1h1a3 3 0 0 1 3 3v1a3 3 0 0 1-3 3h-1v4a4 4 0 0 1-8 0v-4H7a3 3 0 0 1-3-3v-1a3 3 0 0 1 3-3h1V6a4 4 0 0 1 4-4z"/></svg>
                免費解鎖 AI 解卦
              </button>
            </form>
            <p class="ai-gate-trust">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              已有 2,000+ 人使用，不寄垃圾信
            </p>
          </div>
          <!-- Loading -->
          <div id="aiLoading" style="display:none;text-align:center;padding:2rem">
            <div class="ai-spinner"></div>
            <p style="margin-top:1rem;color:var(--mid-gray,#6b7280);font-size:.9rem">AI 正在為你解讀卦象...</p>
          </div>
          <!-- AI Result -->
          <div id="aiResult" style="display:none" class="ai-result-content"></div>
          <!-- Consultation Upsell (hidden until AI result shows) -->
          <div id="consultUpsell" style="display:none" class="consult-upsell">
            <div class="consult-upsell-badge">限量名額</div>
            <h3 class="consult-upsell-title">想要更深入的解讀？</h3>
            <p class="consult-upsell-desc">AI 解卦提供方向性指引，但每個人的命局不同。<strong>真人大師一對一諮詢</strong>，結合你的生辰八字與當前卦象，給你最精準的人生建議。</p>
            <div class="consult-upsell-features">
              <div class="consult-feature">
                <svg width="20" height="20" fill="none" stroke="var(--jade,#2d8a56)" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span>一對一視訊 / 語音諮詢 60 分鐘</span>
              </div>
              <div class="consult-feature">
                <svg width="20" height="20" fill="none" stroke="var(--jade,#2d8a56)" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span>結合八字命盤 + 卦象雙重分析</span>
              </div>
              <div class="consult-feature">
                <svg width="20" height="20" fill="none" stroke="var(--jade,#2d8a56)" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span>專屬文字報告 + 後續追蹤</span>
              </div>
            </div>
            <a href="mailto:contact@zenkami.com?subject=預約易經諮詢&body=您好，我想預約一對一易經諮詢。%0A%0A我的問題是：%0A我的卦象是：" id="consultBtn" class="consult-upsell-btn">
              預約諮詢（名額有限）
            </a>
            <p class="consult-upsell-note">回覆時間約 24 小時內 ・ 首次諮詢享優惠價</p>
          </div>
        </div>

        <!-- Actions -->
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:2rem">
          <button id="retryBtn" class="cta-btn cta-btn--secondary" style="display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.5rem;border-radius:8px;font-weight:600;cursor:pointer">重新占卦</button>
          <a id="lookupLink" href="/tools/hexagram-lookup" class="cta-btn cta-btn--primary" style="display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.5rem;border-radius:8px;font-weight:600;text-decoration:none">查看完整卦象</a>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Methodology section -->
<section class="section" style="padding-top:3rem;border-top:1px solid var(--border-color,#e5e5e8)">
  <div class="container" style="max-width:720px">
    <h2 style="font-size:1.3rem;margin-bottom:1rem;text-align:center">關於三幣法</h2>
    <p style="color:var(--mid-gray,var(--c-text-muted));text-align:center;max-width:600px;margin:0 auto 1.5rem;font-size:.9rem">
      三幣法是最常用的易經占卦方法。使用三枚銅錢（正面為 3、反面為 2），每次擲出三枚銅錢，
      將三枚銅錢的數字相加：6 為老陰（變爻）、7 為少陽、8 為少陰、9 為老陽（變爻）。
      連續擲六次，由下往上排列，即得一卦。
    </p>
    <div style="text-align:center">
      <a href="/articles/three-coins-method" style="color:var(--jade,var(--c-primary));font-size:.9rem">了解更多三幣法的細節 &rarr;</a>
    </div>
  </div>
</section>

<script>
  import { hexagrams, getHexagramByNumber, kingWenTable } from '../../lib/hexagrams';
  import type { Hexagram } from '../../lib/hexagrams';

  interface LineResult {
    value: 6 | 7 | 8 | 9;
    coins: [number, number, number];
    isYang: boolean;
    isChanging: boolean;
  }

  // Store current result for AI
  let currentHex: Hexagram | null = null;
  let currentTransformedHex: Hexagram | null = null;
  let currentChangingIndices: number[] = [];

  function throwCoins(): LineResult {
    const coins: [number, number, number] = [
      Math.random() < 0.5 ? 2 : 3,
      Math.random() < 0.5 ? 2 : 3,
      Math.random() < 0.5 ? 2 : 3,
    ];
    const sum = coins[0] + coins[1] + coins[2];
    return {
      value: sum as 6 | 7 | 8 | 9,
      coins,
      isYang: sum === 7 || sum === 9,
      isChanging: sum === 6 || sum === 9,
    };
  }

  function trigramIndex(l1: number, l2: number, l3: number): number {
    const bin = l3 * 4 + l2 * 2 + l1;
    return 7 - bin;
  }

  function lineToYinYang(v: number): number {
    return (v === 7 || v === 9) ? 1 : 0;
  }

  function lineToTransformed(v: number): number {
    if (v === 9) return 0;
    if (v === 6) return 1;
    return lineToYinYang(v);
  }

  const params = new URLSearchParams(window.location.search);
  const preQ = params.get('q');
  if (preQ) {
    const input = document.getElementById('questionInput') as HTMLTextAreaElement;
    if (input) input.value = preQ;
  }

  const stepQuestion = document.getElementById('step-question')!;
  const stepThrowing = document.getElementById('step-throwing')!;
  const stepResult = document.getElementById('step-result')!;
  const startBtn = document.getElementById('startBtn')!;
  const retryBtn = document.getElementById('retryBtn')!;
  const throwsContainer = document.getElementById('throwsContainer')!;

  function renderHexLine(isYang: boolean, isChanging: boolean): HTMLElement {
    const line = document.createElement('div');
    line.style.cssText = 'width:100px;height:10px;display:flex;justify-content:space-between;position:relative';
    if (isYang) {
      line.innerHTML = `<div style="width:100%;height:100%;background:var(--jade,#2d8a56);border-radius:2px;${isChanging?'animation:pulse-line 1.5s infinite':''}"></div>`;
    } else {
      line.innerHTML = `<div style="width:42px;height:100%;background:var(--jade,#2d8a56);border-radius:2px;${isChanging?'animation:pulse-line 1.5s infinite':''}"></div><div style="width:42px;height:100%;background:var(--jade,#2d8a56);border-radius:2px;${isChanging?'animation:pulse-line 1.5s infinite':''}"></div>`;
    }
    if (isChanging) {
      const marker = document.createElement('span');
      marker.textContent = isYang ? 'o' : 'x';
      marker.style.cssText = 'position:absolute;right:-20px;top:50%;transform:translateY(-50%);font-size:.7rem;color:var(--bronze,#b8860b)';
      line.appendChild(marker);
    }
    return line;
  }

  async function runDivination() {
    stepQuestion.style.display = 'none';
    stepThrowing.style.display = '';
    stepResult.style.display = 'none';
    throwsContainer.innerHTML = '';

    // Reset AI section
    document.getElementById('aiGate')!.style.display = '';
    document.getElementById('aiLoading')!.style.display = 'none';
    document.getElementById('aiResult')!.style.display = 'none';
    document.getElementById('consultUpsell')!.style.display = 'none';
    const unlockBtn = document.getElementById('aiUnlockBtn') as HTMLButtonElement;
    unlockBtn.textContent = '免費解鎖 AI 解卦';
    unlockBtn.disabled = false;

    const lines: LineResult[] = [];

    for (let i = 0; i < 6; i++) {
      const result = throwCoins();
      lines.push(result);

      const row = document.createElement('div');
      row.style.cssText = 'display:flex;align-items:center;gap:1rem;opacity:0;transition:opacity .4s';
      const label = document.createElement('span');
      label.style.cssText = 'font-size:.85rem;color:var(--mid-gray,#6b7280);min-width:50px';
      label.textContent = `第${i+1}爻`;
      const coins = document.createElement('div');
      coins.style.cssText = 'display:flex;gap:.5rem';
      result.coins.forEach(c => {
        const coin = document.createElement('span');
        coin.style.cssText = 'width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;background:var(--bronze,#b8860b);color:var(--near-black,#1a1a2e)';
        coin.textContent = c === 3 ? '正' : '反';
        coins.appendChild(coin);
      });
      const val = document.createElement('span');
      val.style.cssText = 'font-size:.85rem;font-weight:600;min-width:60px';
      const labels: Record<number,string> = {6:'老陰 ⚋',7:'少陽 ⚊',8:'少陰 ⚋',9:'老陽 ⚊'};
      val.textContent = `= ${result.value} ${labels[result.value]}`;
      if (result.isChanging) val.style.color = 'var(--bronze,#b8860b)';
      row.appendChild(label);
      row.appendChild(coins);
      row.appendChild(val);
      throwsContainer.appendChild(row);

      await new Promise(r => setTimeout(r, 600));
      row.style.opacity = '1';
    }

    await new Promise(r => setTimeout(r, 800));
    showResult(lines);
  }

  function showResult(lines: LineResult[]) {
    stepThrowing.style.display = 'none';
    stepResult.style.display = '';

    currentChangingIndices = lines.map((l, i) => l.isChanging ? i : -1).filter(i => i >= 0);
    const primaryYY = lines.map(l => lineToYinYang(l.value));
    const lowerIdx = trigramIndex(primaryYY[0], primaryYY[1], primaryYY[2]);
    const upperIdx = trigramIndex(primaryYY[3], primaryYY[4], primaryYY[5]);
    const hexNum = kingWenTable[lowerIdx][upperIdx];
    const hex = getHexagramByNumber(hexNum);

    if (!hex) return;
    currentHex = hex;

    // Render hexagram visualization
    const viz = document.getElementById('hexagramViz')!;
    viz.innerHTML = '';
    for (let i = 5; i >= 0; i--) {
      viz.appendChild(renderHexLine(primaryYY[i] === 1, lines[i].isChanging));
    }

    document.getElementById('hexagramName')!.textContent = `第${hex.number}卦 ${hex.fullName}（${hex.name}）`;
    document.getElementById('hexagramPinyin')!.textContent = `${hex.pinyin} ｜ ${hex.element}`;
    document.getElementById('hexagramNature')!.textContent = hex.nature;

    // Keywords
    const kwContainer = document.getElementById('hexagramKeywords')!;
    kwContainer.innerHTML = '';
    hex.keywords.forEach(kw => {
      const tag = document.createElement('span');
      tag.style.cssText = 'padding:.2rem .6rem;background:var(--jade-subtle,rgba(45,138,86,.1));color:var(--jade,#2d8a56);border-radius:20px;font-size:.75rem;font-weight:600';
      tag.textContent = kw;
      kwContainer.appendChild(tag);
    });

    document.getElementById('hexagramJudgment')!.textContent = hex.judgment;
    document.getElementById('hexagramImage')!.textContent = hex.image;

    // All 6 lines with text + meaning
    const allLinesEl = document.getElementById('allLinesContent')!;
    allLinesEl.innerHTML = '';
    const posNames = ['初', '二', '三', '四', '五', '上'];
    hex.lines.forEach((line, idx) => {
      const isChanging = currentChangingIndices.includes(idx);
      const div = document.createElement('div');
      div.style.cssText = `padding:1rem;margin-bottom:.5rem;border-radius:8px;border-left:3px solid ${isChanging ? 'var(--bronze,#b8860b)' : 'var(--jade,#2d8a56)'};background:${isChanging ? 'var(--bronze-subtle,rgba(184,134,11,.1))' : 'var(--off-white,#f5f4f0)'}`;
      div.innerHTML = `
        <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.35rem">
          <span style="font-weight:700;font-size:.8rem;color:${isChanging ? 'var(--bronze,#b8860b)' : 'var(--jade,#2d8a56)'}">第${posNames[idx]}爻${isChanging ? '（動爻）' : ''}</span>
        </div>
        <p style="font-family:var(--ff-serif);font-size:.9rem;margin:0 0 .35rem 0">${line.text}</p>
        <p style="font-size:.8rem;color:var(--mid-gray,#6b7280);margin:0">→ ${line.meaning}</p>
      `;
      allLinesEl.appendChild(div);
    });

    // Lookup link
    (document.getElementById('lookupLink') as HTMLAnchorElement).href = `/tools/hexagram-lookup#hex-${hex.number}`;

    // Changing lines highlight
    if (currentChangingIndices.length > 0) {
      document.getElementById('changingLinesSection')!.style.display = '';
      const content = document.getElementById('changingLinesContent')!;
      content.innerHTML = `<p style="font-size:.9rem;color:var(--mid-gray,#6b7280);margin:0">
        本次占卦共有 <strong style="color:var(--bronze,#b8860b)">${currentChangingIndices.length}</strong> 個動爻（${currentChangingIndices.map(i => `第${posNames[i]}爻`).join('、')}），代表卦象正處於變動之中。動爻是解卦的重點，它暗示著當前局勢的轉折方向。
      </p>`;

      // Transformed hexagram
      const transYY = lines.map(l => lineToTransformed(l.value));
      const tLowerIdx = trigramIndex(transYY[0], transYY[1], transYY[2]);
      const tUpperIdx = trigramIndex(transYY[3], transYY[4], transYY[5]);
      const tHexNum = kingWenTable[tLowerIdx][tUpperIdx];
      const tHex = getHexagramByNumber(tHexNum);

      if (tHex) {
        currentTransformedHex = tHex;
        document.getElementById('transformedSection')!.style.display = '';
        const tViz = document.getElementById('transformedViz')!;
        tViz.innerHTML = '';
        for (let i = 5; i >= 0; i--) {
          tViz.appendChild(renderHexLine(transYY[i] === 1, false));
        }
        document.getElementById('transformedName')!.textContent = `第${tHex.number}卦 ${tHex.fullName}（${tHex.name}）`;
        document.getElementById('transformedPinyin')!.textContent = tHex.pinyin;
        document.getElementById('transformedJudgment')!.textContent = tHex.judgment;
      }
    } else {
      currentTransformedHex = null;
      document.getElementById('changingLinesSection')!.style.display = 'none';
      document.getElementById('transformedSection')!.style.display = 'none';
    }

    // Auto-scroll to email gate after a brief delay
    setTimeout(() => {
      document.getElementById('aiGate')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 600);
  }

  // AI Interpretation with Email Gate
  const aiEmailForm = document.getElementById('aiEmailForm')!;
  const aiGate = document.getElementById('aiGate')!;
  const aiLoading = document.getElementById('aiLoading')!;
  const aiResult = document.getElementById('aiResult')!;
  const consultUpsell = document.getElementById('consultUpsell')!;

  async function requestAiInterpretation() {
    if (!currentHex) return;

    const question = (document.getElementById('questionInput') as HTMLTextAreaElement).value.trim();
    aiGate.style.display = 'none';
    aiLoading.style.display = '';
    aiResult.style.display = 'none';
    consultUpsell.style.display = 'none';

    const changingLines = currentChangingIndices.map(idx => ({
      position: idx + 1,
      text: currentHex!.lines[idx].text,
      meaning: currentHex!.lines[idx].meaning,
    }));

    try {
      const res = await fetch('/api/interpret', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          question: question || undefined,
          hexagramName: currentHex.name,
          hexagramFullName: currentHex.fullName,
          hexagramNumber: currentHex.number,
          judgment: currentHex.judgment,
          image: currentHex.image,
          nature: currentHex.nature,
          keywords: currentHex.keywords,
          changingLines,
          transformedName: currentTransformedHex?.fullName,
          transformedJudgment: currentTransformedHex?.judgment,
        }),
      });

      const data = await res.json();
      if (data.error) throw new Error(data.error);

      aiLoading.style.display = 'none';
      aiResult.style.display = '';
      aiResult.innerHTML = renderMarkdown(data.interpretation);

      // Scroll to AI result
      aiResult.scrollIntoView({ behavior: 'smooth', block: 'start' });

      // Show consultation upsell after AI result
      consultUpsell.style.display = '';
      // Pre-fill consultation email with hexagram info
      const consultBtn = document.getElementById('consultBtn') as HTMLAnchorElement;
      const hexInfo = `第${currentHex.number}卦 ${currentHex.fullName}（${currentHex.name}）`;
      consultBtn.href = `mailto:contact@zenkami.com?subject=預約易經諮詢&body=您好，我想預約一對一易經諮詢。%0A%0A我的問題是：${encodeURIComponent(question || '（未填寫）')}%0A我的卦象是：${encodeURIComponent(hexInfo)}%0A%0A請問最近有空的時段是？`;
    } catch (err: unknown) {
      aiLoading.style.display = 'none';
      aiGate.style.display = '';
      const msg = err instanceof Error ? err.message : '未知錯誤';
      aiResult.style.display = '';
      aiResult.innerHTML = `<div style="padding:1rem;background:#fef2f2;border-radius:8px;color:#991b1b;font-size:.9rem">解卦失敗：${msg}。請稍後再試。</div>`;
    }
  }

  aiEmailForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = document.getElementById('aiEmailInput') as HTMLInputElement;
    const email = emailInput.value.trim();
    if (!email) return;

    const btn = document.getElementById('aiUnlockBtn') as HTMLButtonElement;
    btn.textContent = '處理中...';
    btn.disabled = true;

    // Subscribe email (fire and forget, don't block AI)
    fetch('/api/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email }),
    }).catch(() => {});

    // Request AI interpretation
    await requestAiInterpretation();
  });

  function renderMarkdown(text: string): string {
    return text
      .replace(/^## (.+)$/gm, '<h3 class="ai-heading">$1</h3>')
      .replace(/^### (.+)$/gm, '<h4 class="ai-subheading">$1</h4>')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\n\n/g, '</p><p>')
      .replace(/\n- /g, '</p><li>')
      .replace(/\n/g, '<br>')
      .replace(/<\/p><li>/g, '</p><ul><li>')
      .replace(/<li>([^<]*?)(?=<\/p>|<li>|$)/g, '<li>$1</li>')
      .replace(/(<\/li>)(?![\s\S]*<li>)/g, '$1</ul>')
      .replace(/^/, '<p>')
      .replace(/$/, '</p>');
  }

  startBtn.addEventListener('click', runDivination);
  retryBtn.addEventListener('click', () => {
    stepQuestion.style.display = '';
    stepThrowing.style.display = 'none';
    stepResult.style.display = 'none';
    currentHex = null;
    currentTransformedHex = null;
    currentChangingIndices = [];
  });
</script>

